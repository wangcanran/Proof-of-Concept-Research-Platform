// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
datasource db {
  provider = "mysql"  // 改为 mysql
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(50)
  password  String   @db.VarChar(255)
  email     String   @unique @db.VarChar(100)
  realName  String   @map("real_name") @db.VarChar(50)
  role      Role     @db.Enum(["APPLICANT", "REVIEWER", "ASSISTANT", "ADMIN"])
  college   String?  @db.VarChar(100)
  phone     String?  @db.VarChar(20)
  
  // 关系
  projects  Project[] @relation("ApplicantProjects")
  reviews   Review[]
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(200)
  type        String   @db.VarChar(50)
  abstract    String   @db.Text
  keywords    String[] @db.VarChar(50)
  budget      Float    @db.Decimal(12, 2)
  duration    Int
  status      Status   @default(DRAFT) @db.Enum(["DRAFT", "SUBMITTED", "UNDER_REVIEW", "APPROVED", "REJECTED", "ONGOING", "COMPLETED"])
  
  // 关系
  applicant   User     @relation("ApplicantProjects", fields: [applicantId], references: [id])
  applicantId Int      @map("applicant_id")
  reviews     Review[]
  
  college     String?  @db.VarChar(100)
  applyDate   DateTime @map("apply_date")
  deadline    DateTime?
  attachments Json?    // MySQL 5.7+ 支持 JSON 类型
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("projects")
}

model Review {
  id                    Int      @id @default(autoincrement())
  
  // 关系
  project               Project  @relation(fields: [projectId], references: [id])
  projectId             Int      @map("project_id")
  reviewer              User     @relation(fields: [reviewerId], references: [id])
  reviewerId            Int      @map("reviewer_id")
  
  // 评分
  innovationScore       Int?     @map("innovation_score")
  scientificScore       Int?     @map("scientific_score")
  feasibilityScore      Int?     @map("feasibility_score")
  valueScore            Int?     @map("value_score")
  totalScore            Int?     @map("total_score")
  
  // 结论
  conclusion            Conclusion? @db.Enum(["PASS", "MODIFY", "REJECT"])
  fundingRecommendation FundingRecommendation? @map("funding_recommendation") @db.Enum(["FULL", "PARTIAL", "NONE"])
  suggestedAmount       Float?   @map("suggested_amount") @db.Decimal(12, 2)
  
  // 意见
  detailedComments      String?  @map("detailed_comments") @db.Text
  confidentialComments  String?  @map("confidential_comments") @db.Text
  attachments           Json?
  
  submitTime            DateTime? @map("submit_time")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([projectId, reviewerId])
  @@map("reviews")
}

// 枚举类型 - 在MySQL中会自动创建为ENUM类型
enum Role {
  APPLICANT
  REVIEWER
  ASSISTANT
  ADMIN
}

enum Status {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ONGOING
  COMPLETED
}

enum Conclusion {
  PASS
  MODIFY
  REJECT
}

enum FundingRecommendation {
  FULL
  PARTIAL
  NONE
}